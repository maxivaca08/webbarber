---
import Layout from '../../layouts/Layout.astro'
---
<Layout>
  <div class="animate-fade-up">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-9">
      <div>
        <span class="page-label">Gestión</span>
        <h1 class="page-title">Clientes</h1>
      </div>
      <a href="/clientes/nuevo" class="btn-primary">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="7" y1="1" x2="7" y2="13"/>
          <line x1="1" y1="7" x2="13" y2="7"/>
        </svg>
        Nuevo cliente
      </a>
    </div>
    <div id="table"><div class="loading-state">Cargando...</div></div>
  </div>
</Layout>
<script>
  import { api } from "../../lib/api"
  async function load() {
    const c = document.getElementById("table")
    try {
      const rows = await api.clientes.list()
      if (!rows.length) {
        c.innerHTML = '<div class="card"><div class="empty-state"><div class="empty-state-icon"><svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="7" cy="6" r="3"/><circle cx="14" cy="6" r="2.5"/><path d="M1 17c0-3.3 2.7-6 6-6s6 2.7 6 6"/><path d="M11.5 17c0-2.2 1.8-4 4-4s4 1.8 4 4"/></svg></div>No hay clientes registrados.</div></div>'
        return
      }
      c.innerHTML = rows.map((r, i) =>
        `<div class="card-row animate-fade-up" style="animation-delay:${i*0.03}s;">
          <div class="avatar">${r.nombre.charAt(0).toUpperCase()}${r.apellido.charAt(0).toUpperCase()}</div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-[15px]" style="color:var(--color-text);">${r.nombre} ${r.apellido}</div>
            <div class="flex items-center gap-3 mt-0.5 text-[13px]" style="color:var(--color-text-tertiary);">
              <span>${r.telefono || '—'}</span>
              ${r.email ? `<span>·</span><span>${r.email}</span>` : ''}
              <span>·</span><span>Desde ${r.creado_en.slice(0, 10)}</span>
            </div>
          </div>
          <div class="flex items-center gap-1 shrink-0">
            <a href="/clientes/${r.id}" class="btn-ghost">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M10.5 1.5l2 2L5 11H3V9l7.5-7.5z"/></svg>
              Editar
            </a>
            <button data-id="${r.id}" class="btn-danger">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="3" y1="3" x2="11" y2="11"/><line x1="11" y1="3" x2="3" y2="11"/></svg>
            </button>
          </div>
        </div>`
      ).join('')
      document.querySelectorAll('.btn-danger').forEach(b => b.addEventListener('click', async () => {
        if (!confirm('¿Eliminar este cliente?')) return
        try { await api.clientes.delete(Number((b).dataset.id)); load() }
        catch (e) { alert(e.message) }
      }))
    } catch (e) { c.innerHTML = `<div class="card"><div class="error-state">Error: ${e.message}</div></div>` }
  }
  load()
</script>
