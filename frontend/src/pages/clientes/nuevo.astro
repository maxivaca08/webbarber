---
import Layout from '../../layouts/Layout.astro'
---
<Layout>
  <div class="animate-fade-up" style="max-width: 640px;">
    <div class="mb-8">
      <a href="/clientes" class="back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 3L6 7l4.5 4"/></svg>
        Volver
      </a>
      <h1 class="page-title mt-2">Nuevo Cliente</h1>
    </div>
    <form id="form" class="card p-6 md:p-7 space-y-5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="form-group">
          <span class="form-label">Nombre *</span>
          <input type="text" name="nombre" class="form-input" required>
        </div>
        <div class="form-group">
          <span class="form-label">Apellido *</span>
          <input type="text" name="apellido" class="form-input" required>
        </div>
        <div class="form-group">
          <span class="form-label">Teléfono</span>
          <input type="tel" name="telefono" class="form-input">
        </div>
        <div class="form-group">
          <span class="form-label">Email</span>
          <input type="email" name="email" class="form-input">
        </div>
      </div>
      <hr class="divider">
      <div class="flex items-center gap-3">
        <button type="submit" class="btn-primary">Guardar</button>
        <a href="/clientes" class="btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</Layout>
<script>
  import { api } from "../../lib/api"
  document.getElementById("form").addEventListener('submit', async e => {
    e.preventDefault()
    try { await api.clientes.create(Object.fromEntries(new FormData(e.target).entries())); window.location.href = '/clientes' }
    catch (e) { alert(e.message) }
  })
</script>
