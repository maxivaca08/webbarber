---
import Layout from '../../layouts/Layout.astro'
---
<Layout>
  <div class="animate-fade-up" style="max-width: 640px;">
    <div class="mb-8">
      <a href="/servicios" class="back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.5 3L6 7l4.5 4"/></svg>
        Volver
      </a>
      <h1 class="page-title mt-2">Nuevo Servicio</h1>
    </div>
    <form id="form" class="card p-6 md:p-7 space-y-5">
      <div class="grid grid-cols-1 gap-4">
        <div class="form-group">
          <span class="form-label">Nombre *</span>
          <input type="text" name="nombre" class="form-input" required>
        </div>
        <div class="form-group">
          <span class="form-label">Descripción</span>
          <textarea name="descripcion" class="form-textarea" rows="3"></textarea>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="form-group">
            <span class="form-label">Duración (min) *</span>
            <input type="number" name="duracion_minutos" min="5" step="5" value="30" class="form-input" required>
          </div>
          <div class="form-group">
            <span class="form-label">Precio ($) *</span>
            <input type="number" name="precio" min="0" step="0.01" class="form-input" required>
          </div>
        </div>
      </div>
      <hr class="divider">
      <div class="flex items-center gap-3">
        <button type="submit" class="btn-primary">Guardar</button>
        <a href="/servicios" class="btn-secondary">Cancelar</a>
      </div>
    </form>
  </div>
</Layout>
<script>
  import { api } from "../../lib/api"
  document.getElementById("form").addEventListener('submit', async e => {
    e.preventDefault()
    const fd = new FormData(e.target)
    const data = Object.fromEntries(fd.entries())
    data.duracion_minutos = Number(data.duracion_minutos); data.precio = Number(data.precio)
    try { await api.servicios.create(data); window.location.href = '/servicios' }
    catch (e) { alert(e.message) }
  })
</script>
