---
import Layout from '../../layouts/Layout.astro'
---
<Layout>
  <div class="animate-fade-up">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-9">
      <div>
        <span class="page-label">Catálogo</span>
        <h1 class="page-title">Servicios</h1>
      </div>
      <a href="/servicios/nuevo" class="btn-primary">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="7" y1="1" x2="7" y2="13"/>
          <line x1="1" y1="7" x2="13" y2="7"/>
        </svg>
        Nuevo servicio
      </a>
    </div>
    <div id="table"><div class="loading-state">Cargando...</div></div>
  </div>
</Layout>
<script>
  import { api } from "../../lib/api"
  const fmt = (n) => '$' + n.toLocaleString('es-AR')
  async function load() {
    const c = document.getElementById("table")
    try {
      const rows = await api.servicios.list()
      if (!rows.length) {
        c.innerHTML = '<div class="card"><div class="empty-state"><div class="empty-state-icon"><svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10 1.5l2.5 5 5.5.8-4 3.9 1 5.3L10 14l-5 2.5 1-5.3-4-3.9 5.5-.8L10 1.5z"/></svg></div>No hay servicios registrados.</div></div>'
        return
      }
      c.innerHTML = rows.map((r, i) =>
        `<div class="card-row animate-fade-up" style="animation-delay:${i*0.03}s;">
          <div class="avatar" style="background:var(--color-surface-2);color:var(--color-text-tertiary);">${r.nombre.charAt(0).toUpperCase()}</div>
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 flex-wrap">
              <span class="font-semibold text-[15px]" style="color:var(--color-text);">${r.nombre}</span>
              <span class="text-[13px] font-medium" style="color:var(--color-text-tertiary);">${r.duracion_minutos} min</span>
              <span class="font-semibold text-sm" style="color:var(--color-accent);">${fmt(r.precio)}</span>
            </div>
            <div class="text-[13px] mt-0.5" style="color:var(--color-text-tertiary);">${r.descripcion || 'Sin descripción'}</div>
          </div>
          <div class="flex items-center gap-1 shrink-0">
            <a href="/servicios/${r.id}" class="btn-ghost">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M10.5 1.5l2 2L5 11H3V9l7.5-7.5z"/></svg>
              Editar
            </a>
            <button data-id="${r.id}" class="btn-danger">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="3" y1="3" x2="11" y2="11"/><line x1="11" y1="3" x2="3" y2="11"/></svg>
            </button>
          </div>
        </div>`
      ).join('')
      document.querySelectorAll('.btn-danger').forEach(b => b.addEventListener('click', async () => {
        if (!confirm('¿Eliminar este servicio?')) return
        try { await api.servicios.delete(Number((b).dataset.id)); load() }
        catch (e) { alert(e.message) }
      }))
    } catch (e) { c.innerHTML = `<div class="card"><div class="error-state">Error: ${e.message}</div></div>` }
  }
  load()
</script>
