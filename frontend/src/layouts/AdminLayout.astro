---
import '../styles/global.css';
import { apiFetch } from '../utils/api';

interface Props {
  title: string;
  active: string;
  userName: string;
  alerts?: { cat: string; msg: string }[];
}
const { title, active, userName, alerts = [] } = Astro.props;

const notifRes = await apiFetch('/api/admin/notificaciones', Astro.request);
const { reprogramados = 0 } = notifRes.ok ? await notifRes.json() : {};

const navItems = [
  { href: '/admin',               label: 'Dashboard',      icon: '🏠', key: 'dashboard', badge: 0 },
  { href: '/admin/turnos',        label: 'Turnos',         icon: '📅', key: 'turnos',    badge: reprogramados },
  { href: '/admin/clientes',      label: 'Clientes',       icon: '👥', key: 'clientes',  badge: 0 },
  { href: '/admin/disponibilidad',label: 'Disponibilidad', icon: '⚙️', key: 'disponibilidad', badge: 0 },
  { href: '/admin/pendientes',    label: 'Pendientes',     icon: '⏳', key: 'pendientes', badge: 0 },
];
---
<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — BarberApp</title>
  <slot name="head" />
</head>
<body class="app-body">

<!-- Desktop sidebar -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="icon">✂️</div>
    <div>
      <h1>BarberApp</h1>
      <span>Panel Admin</span>
    </div>
  </div>
  <nav>
    {navItems.map(n => (
      <a href={n.href} class={active === n.key ? 'active' : ''} style="position:relative">
        <span class="nav-icon">{n.icon}</span>
        <span>{n.label}</span>
        {n.badge > 0 && (
          <span style="position:absolute;top:6px;right:10px;background:#ef4444;color:#fff;font-size:10px;font-weight:700;border-radius:999px;padding:1px 6px;line-height:16px">
            {n.badge}
          </span>
        )}
      </a>
    ))}
  </nav>
  <div class="sidebar-footer">
    <div class="sidebar-user">
      <strong>{userName}</strong>
      <span>Administrador</span>
    </div>
    <a href="/logout" title="Cerrar sesión">🚪</a>
  </div>
</aside>

<!-- Mobile bottom nav -->
<nav class="bottom-nav">
  {navItems.map(n => (
    <a href={n.href} class={active === n.key ? 'active' : ''} style="position:relative">
      <span class="nav-icon">{n.icon}</span>
      <span>{n.label}</span>
      {n.badge > 0 && (
        <span style="position:absolute;top:4px;right:4px;background:#ef4444;color:#fff;font-size:10px;font-weight:700;border-radius:999px;padding:1px 5px;line-height:15px">
          {n.badge}
        </span>
      )}
    </a>
  ))}
  <a href="/logout">
    <span class="nav-icon">🚪</span>
    <span>Salir</span>
  </a>
</nav>

<main class="main">
  {alerts.length > 0 && (
    <div class="alerts">
      {alerts.map(a => (
        <div class={`alert alert-${a.cat}`}>
          {a.cat === 'success' ? '✅' : a.cat === 'info' ? 'ℹ️' : '⚠️'}
          {a.msg}
        </div>
      ))}
    </div>
  )}
  <slot />
</main>

<slot name="scripts" />
</body>
</html>
