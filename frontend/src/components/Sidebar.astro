---
const links = [
  { href: '/', label: 'Dashboard', icon: 'dashboard' },
  { href: '/turnos', label: 'Turnos', icon: 'calendar' },
  { href: '/clientes', label: 'Clientes', icon: 'people' },
  { href: '/barberos', label: 'Barberos', icon: 'scissors' },
  { href: '/servicios', label: 'Servicios', icon: 'star' },
]
const current = Astro.url.pathname
const isActive = (href: string) => current === href || (href !== '/' && current.startsWith(href))
---

<aside class="fixed top-0 left-0 bottom-0 w-[260px] z-50 flex flex-col overflow-hidden bg-sidebar-bg max-md:hidden">
  <div class="px-6 pt-8 pb-5">
    <div class="flex items-center gap-3.5">
      <div class="w-10 h-10 rounded-[10px] flex items-center justify-center shrink-0" style="background: rgba(220, 74, 74, 0.12);">
        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" style="color: #dc4a4a;">
          <circle cx="5" cy="5" r="2.5" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="5" cy="15" r="2.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M7 6l8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M7 14l8-8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div>
        <h1 class="text-lg font-bold leading-tight" style="color: rgba(255,255,255,0.9); letter-spacing: -0.02em;">Barbería</h1>
        <p class="text-[10px] uppercase tracking-[0.2em] font-medium mt-[2px]" style="color: rgba(220, 74, 74, 0.5);">Gestión</p>
      </div>
    </div>
  </div>

  <hr style="border-color: rgba(255,255,255,0.04); margin: 0 16px;">

  <nav class="flex-1 py-5 px-3 space-y-0.5">
    {links.map(link => {
      const active = isActive(link.href)
      return (
        <a href={link.href}
          class="sidebar-link"
          style={{
            background: active ? 'rgba(220, 74, 74, 0.1)' : 'transparent',
            color: active ? '#dc4a4a' : 'rgba(255,255,255,0.3)',
          }}>
          <span class="w-5 h-5 flex items-center justify-center shrink-0">
            {link.icon === 'dashboard' && (
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2.5" y="2.5" width="6" height="6" rx="1.5"/>
                <rect x="11.5" y="2.5" width="6" height="6" rx="1.5"/>
                <rect x="2.5" y="11.5" width="6" height="6" rx="1.5"/>
                <rect x="11.5" y="11.5" width="6" height="6" rx="1.5"/>
              </svg>
            )}
            {link.icon === 'calendar' && (
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2.5" y="4" width="15" height="13.5" rx="2"/>
                <line x1="2.5" y1="8" x2="17.5" y2="8"/>
                <line x1="6.5" y1="1.5" x2="6.5" y2="5"/>
                <line x1="13.5" y1="1.5" x2="13.5" y2="5"/>
              </svg>
            )}
            {link.icon === 'people' && (
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="7" cy="6" r="3"/>
                <circle cx="14" cy="6" r="2.5"/>
                <path d="M1 17c0-3.3 2.7-6 6-6s6 2.7 6 6"/>
                <path d="M11.5 17c0-2.2 1.8-4 4-4s4 1.8 4 4"/>
              </svg>
            )}
            {link.icon === 'scissors' && (
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="5" cy="5" r="2.5"/>
                <circle cx="5" cy="15" r="2.5"/>
                <path d="M7 6l8 8"/>
                <path d="M7 14l8-8"/>
              </svg>
            )}
            {link.icon === 'star' && (
              <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 1.5l2.5 5 5.5.8-4 3.9 1 5.3L10 14l-5 2.5 1-5.3-4-3.9 5.5-.8L10 1.5z"/>
              </svg>
            )}
          </span>
          <span style="font-size: 13px; letter-spacing: 0.02em;">{link.label}</span>
        </a>
      )
    })}
  </nav>

  <div class="px-6 py-5" style="border-top: 1px solid rgba(255,255,255,0.04);">
    <p class="text-[9px] uppercase tracking-[0.2em]" style="color: rgba(255,255,255,0.1);">Barbería &bull; Est. 2024</p>
  </div>
</aside>

<style>
  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 14px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.15s ease;
    text-decoration: none;
  }
  .sidebar-link:hover {
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.5);
  }
</style>
